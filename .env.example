# Admin login password (required for local admin uploads at /Levi-Zigza-Artist-Portfolio/admin/)
ADMIN_PASSWORD=change-me

# Optional: HMAC secret for admin session cookies (defaults to ADMIN_PASSWORD)
SESSION_SECRET=change-me-too

# API listen port (Vite proxies /api here in dev)
PORT=5174

# --- Cowboy VO / neural TTS (optional) ---
# Default bake + /api/tts: Microsoft Edge neural via Python `edge-tts` CLI (no key).
# Install once: pip install edge-tts
# TTS_PROVIDER=edge
# TTS_VOICE=en-US-ChristopherNeural
# TTS_RATE=-20%
# TTS_PITCH=-5Hz

# Optional VoiceRSS (https://www.voicerss.org/) — free key, male voice e.g. Mike
# TTS_PROVIDER=voicerss
# TTS_API_KEY=
# TTS_VOICE=Mike

# Force re-bake all line-XX.mp3: VO_FORCE=1 npm run vo:bake
