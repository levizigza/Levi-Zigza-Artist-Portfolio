# Admin login password (required for local admin uploads at /Levi-Zigza-Artist-Portfolio/admin/)
# Local default below — change before any shared/deployed host.
ADMIN_PASSWORD=admin

# Optional: HMAC secret for admin session cookies (defaults to ADMIN_PASSWORD)
SESSION_SECRET=change-me-too

# API listen port (Vite proxies /api here in dev)
PORT=5174

# --- Supabase Storage (optional cloud uploads) ---
# When set, admin uploads go to the public `portfolio` bucket and the
# media manifest is mirrored to portfolio/manifest.json for GitHub Pages.
# Without these, uploads stay on local public/uploads/ as before.
# Setup SQL: docs/supabase-storage.sql
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_BUCKET=portfolio

# Client-side (Vite) — used on GitHub Pages to fetch the cloud manifest + public media URLs.
# Anon key is optional when reading public bucket objects by URL alone.
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_SUPABASE_BUCKET=portfolio

# Optional Cloudflare Worker URL if you deploy wrangler.toml (GET /api/manifest proxy).
# VITE_MANIFEST_WORKER_URL=https://arist-portfolio-manifest.YOUR_SUBDOMAIN.workers.dev

# --- Cowboy VO / neural TTS (optional) ---
# Default bake + /api/tts: Microsoft Edge neural via Python edge-tts CLI (no key).
# Install once: pip install edge-tts
# TTS_PROVIDER=edge
# TTS_VOICE=en-US-ChristopherNeural
# TTS_RATE=-20%
# TTS_PITCH=-5Hz

# Optional VoiceRSS (https://www.voicerss.org/) — free key, male voice e.g. Mike
# TTS_PROVIDER=voicerss
# TTS_API_KEY=
# TTS_VOICE=Mike

# Force re-bake all line-XX.mp3: VO_FORCE=1 npm run vo:bake
